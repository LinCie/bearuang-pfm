# .env.example — copy values to .dev.vars for local development (never commit .dev.vars)

# Required for first-login bootstrap flow (Story 1.4).
# Set locally in .dev.vars; in production use: bunx wrangler secret put INITIAL_PASSWORD
INITIAL_PASSWORD=replace-with-secure-password

# Wrangler binding IDs — replace these in wrangler.toml before deploying.
# Obtain them by running the commands below once per environment:
#
#   bunx wrangler d1 create bearuang
#   → copy the database_id into wrangler.toml [[d1_databases]] database_id
D1_DATABASE_ID=<replace-with-output-of-wrangler-d1-create>

#   bunx wrangler kv namespace create SESSIONS
#   → copy the id into wrangler.toml [[kv_namespaces]] id
KV_SESSIONS_ID=<replace-with-output-of-wrangler-kv-namespace-create>

#   bunx wrangler r2 bucket create bearuang-receipts
#   → no ID needed in wrangler.toml; bucket_name is sufficient for R2
